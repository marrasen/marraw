{
  "name": "marraw",
  "version": "0.5.1",
  "description": "Fast RAW photo organizer and editor",
  "author": "Marras",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "setup:libraw": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-libraw.ps1",
    "setup:ort": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-ort.ps1",
    "gen": "go run ./tools/generate",
    "gen:icon": "node scripts/gen-icon.mjs",
    "dev:server": "go run ./cmd/marrawd --dev --port 8483",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:electron": "cross-env MARRAW_DEV=1 MARRAW_PORT=8483 electron .",
    "preview:build": "npm run gen && npm run build:client && npm run build:server",
    "preview:run": "cross-env MARRAW_PREVIEW=1 electron .",
    "preview": "npm run preview:build && npm run preview:run",
    "smoke": "node scripts/smoke.mjs",
    "build:server": "node scripts/build-server.mjs",
    "build:client": "npm --prefix client run build",
    "typecheck": "npm --prefix client run typecheck",
    "dist": "npm run gen && npm run build:client && npm run build:server && electron-builder --publish never",
    "dist:publish": "npm run gen && npm run build:client && npm run build:server && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.0.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "se.skalarit.marraw",
    "productName": "marraw",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "marrasen",
        "repo": "marraw",
        "releaseType": "draft"
      }
    ],
    "files": [
      "electron/**",
      "client/dist/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "marraw-Setup-${version}.exe",
      "extraResources": [
        {
          "from": "build/marrawd.exe",
          "to": "marrawd.exe"
        },
        {
          "from": "third_party/onnxruntime/lib",
          "to": "."
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "identity": null,
      "category": "public.app-category.photography",
      "artifactName": "marraw-${version}-${arch}.dmg",
      "extraResources": [
        {
          "from": "build/marrawd",
          "to": "marrawd"
        },
        {
          "from": "third_party/onnxruntime/lib",
          "to": "."
        }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Graphics",
      "maintainer": "marcus@skalarit.se",
      "artifactName": "marraw-${version}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "build/marrawd",
          "to": "marrawd"
        },
        {
          "from": "third_party/onnxruntime/lib",
          "to": "."
        }
      ]
    }
  }
}
