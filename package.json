{
  "name": "marraw",
  "version": "0.2.0",
  "description": "Fast RAW photo organizer and editor",
  "author": "Marras",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "setup:libraw": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-libraw.ps1",
    "gen": "go run ./tools/generate",
    "gen:icon": "node scripts/gen-icon.mjs",
    "dev:server": "go run ./cmd/marrawd --dev --port 8483",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:electron": "cross-env MARRAW_DEV=1 MARRAW_PORT=8483 electron .",
    "preview:build": "npm run gen && npm run build:client && npm run build:server",
    "preview:run": "cross-env MARRAW_PREVIEW=1 electron .",
    "preview": "npm run preview:build && npm run preview:run",
    "smoke": "node scripts/smoke.mjs",
    "build:server": "go build -ldflags \"-s -w\" -o build/marrawd.exe ./cmd/marrawd",
    "build:client": "npm --prefix client run build",
    "typecheck": "npm --prefix client run typecheck",
    "dist": "npm run gen && npm run build:client && npm run build:server && electron-builder --win --publish never",
    "dist:publish": "npm run gen && npm run build:client && npm run build:server && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.0.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "se.skalarit.marraw",
    "productName": "marraw",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "marrasen",
        "repo": "marraw",
        "releaseType": "draft"
      }
    ],
    "files": [
      "electron/**",
      "client/dist/**"
    ],
    "extraResources": [
      {
        "from": "build/marrawd.exe",
        "to": "marrawd.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "marraw-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
